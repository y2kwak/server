connection node_2;
connection node_1;
# On node_2
connection node_2;
SET GLOBAL wsrep_on=OFF;
RESET MASTER;
SET GLOBAL wsrep_on=ON;
# On node_1
connection node_1;
SET GLOBAL wsrep_on=OFF;
RESET MASTER;
SET GLOBAL wsrep_on=ON;
CREATE TABLE t1(i INT)ENGINE=INNODB;
INSERT INTO t1 VALUES(1);
DELETE FROM t1 WHERE i = 1;
# On node_2
connection node_2;
INSERT INTO t1 VALUES(2);
DELETE FROM t1 WHERE i = 2;
