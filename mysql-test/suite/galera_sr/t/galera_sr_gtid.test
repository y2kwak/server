#
# Test basic Galera operation
#

--source include/have_log_bin.inc
--source include/galera_cluster.inc
--source include/have_innodb.inc

CREATE TABLE t1 (f1 INT PRIMARY KEY);

SET SESSION wsrep_trx_fragment_size=1;
INSERT INTO t1 VALUES (1);

--connection node_2
SELECT COUNT(*) = 1 FROM t1;

SET SESSION wsrep_trx_fragment_size=1;
UPDATE t1 SET f1 = 2;

#--let $gtid_executed_node2 = `SELECT @@global.gtid_executed;`

--connection node_1
SET SESSION wsrep_trx_fragment_size=0;

--connection node_2
SET SESSION wsrep_trx_fragment_size=0;

--connection node_1
SELECT COUNT(*) = 1 FROM t1 WHERE f1 = 2;

--disable_query_log
#--eval SELECT '$gtid_executed_node2' = @@global.gtid_executed AS gtid_executed_equal;
--enable_query_log

--let $binlog_file=mysqld-bin.000002
--source include/show_binlog_events.inc

--connection node_2
# Perform causal wait
SELECT 1 FROM DUAL;

--let $binlog_file=mysqld-bin.000003
--source include/show_binlog_events.inc

DROP TABLE t1;
